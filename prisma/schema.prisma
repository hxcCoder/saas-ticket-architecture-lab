datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")  // obligatorio
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

// Tablas existentes
model Execution {
  id        String          @id
  processId String
  status    String
  steps     ExecutionStep[]
}

model ExecutionStep {
  id          String   @id @default(uuid())
  executionId String
  stepId      String
  status      String
  execution   Execution @relation(fields: [executionId], references: [id])
}

model auditLog {
  id         String   @id @default(uuid())
  eventId    String
  eventName  String
  eventData  Json
  occurredOn DateTime
  payload    Json
}

model Outbox {
  id         String   @id @default(cuid())
  eventName  String
  payload    Json
  occurredOn DateTime
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
